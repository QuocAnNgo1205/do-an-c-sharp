@using VinhKhanhFoodTour.AdminPortal.Services.Auth
@inject AuthService AuthService
@inject AuthState AuthState

<CascadingValue Value="AuthState">
    @if (!_isReady)
    {
        <!-- Loading screen trong lúc chờ khôi phục auth -->
        <div style="display:flex;align-items:center;justify-content:center;height:100vh;background:#f3f4f6;">
            <div style="text-align:center;">
                <div style="width:48px;height:48px;border:4px solid #e5e7eb;border-top:4px solid #0284c7;border-radius:50%;animation:spin 0.8s linear infinite;margin:0 auto 16px;"></div>
                <p style="color:#6b7280;font-size:14px;">Đang tải...</p>
            </div>
        </div>
        <style>
            @@keyframes spin { to { transform: rotate(360deg); } }
        </style>
    }
    else
    {
        <Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.NotFound)">
            <Found Context="routeData">
                <RouteView RouteData="routeData" DefaultLayout="typeof(Layout.AppLayout)" />
                <FocusOnNavigate RouteData="routeData" Selector="h1" />
            </Found>
        </Router>
    }
</CascadingValue>

@code {
    private bool _isReady = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Ở đây đã chạy Interactive Server → JS Interop sẵn sàng → gọi LocalStorage an toàn
            await AuthService.RestoreAuthAsync();
            _isReady = true;
            StateHasChanged();
        }
    }
}
