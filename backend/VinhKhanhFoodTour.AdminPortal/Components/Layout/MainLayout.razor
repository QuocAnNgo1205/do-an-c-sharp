@using VinhKhanhFoodTour.AdminPortal.Services.Auth
@inherits LayoutComponentBase

<div class="app-container flex h-screen bg-gray-100">
    <!-- Sidebar -->
    <Sidebar />
    
    <!-- Main Content -->
    <div class="flex flex-col flex-1">
        <!-- Top Navigation -->
        <TopNav />
        
        <!-- Page Content -->
        <main class="flex-1 overflow-auto p-6">
            <article class="max-w-7xl mx-auto">
                @Body
            </article>
        </main>
    </div>
</div>

<div id="blazor-error-ui" class="fixed bottom-4 right-4 bg-red-500 text-white p-4 rounded shadow-lg" data-nosnippet>
    <p class="font-bold">An unhandled error has occurred.</p>
    <a href="." class="text-blue-200 hover:text-white underline">Reload</a>
    <button class="ml-4 text-blue-200 hover:text-white">✕</button>
</div>

