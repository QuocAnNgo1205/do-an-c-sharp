@using VinhKhanhFoodTour.AdminPortal.Services.Auth

<aside class="w-64 bg-slate-900 text-white shadow-lg flex flex-col">
    <!-- Logo / Brand -->
    <div class="p-6 border-b border-slate-700">
        <h1 class="text-2xl font-bold">Vinh Khánh</h1>
        <p class="text-sm text-slate-400 mt-1">Quản lý Food Tour</p>
    </div>

    <!-- Menu Items -->
    <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
        @if (AuthState?.IsAuthenticated == true)
        {
            @if (AuthState.IsOwner)
            {
                <!-- Owner Menu -->
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                    <span class="icon">🏠</span>
                    <span>Quán của tôi</span>
                </NavLink>
                
                <NavLink class="nav-link" href="/owner/statistics">
                    <span class="icon">📊</span>
                    <span>Thống kê lượt nghe</span>
                </NavLink>

                <NavLink class="nav-link" href="/qr-management">
                    <span class="icon">📷</span>
                    <span>Quản lý mã QR</span>
                </NavLink>

                <NavLink class="nav-link" href="/poi-map">
                    <span class="icon">📍</span>
                    <span>Bản đồ của tôi</span>
                </NavLink>


            }
            else if (AuthState.IsAdmin)
            {
                <!-- Admin Menu -->
                <NavLink class="nav-link" href="/" Match="NavLinkMatch.All">
                    <span class="icon">🏠</span>
                    <span>Dashboard & Phê duyệt</span>
                </NavLink>
                

                
                <NavLink class="nav-link" href="/admin/users">
                    <span class="icon">👥</span>
                    <span>Quản lý người dùng</span>
                </NavLink>

                <NavLink class="nav-link" href="/poi-map">
                    <span class="icon">📍</span>
                    <span>Bản đồ hệ thống</span>
                </NavLink>

                <NavLink class="nav-link" href="/tour-builder">
                    <span class="icon">🗺️</span>
                    <span>Xây dựng Tour</span>
                </NavLink>

                <NavLink class="nav-link" href="/admin/qr-management">
                    <span class="icon">📷</span>
                    <span>Quản lý QR tổng</span>
                </NavLink>

                <NavLink class="nav-link" href="/admin/audio">
                    <span class="icon">🎵</span>
                    <span>Quản lý âm thanh</span>
                </NavLink>
            }
        }
    </nav>

    <div class="border-t border-slate-700 p-4">
        @if (AuthState?.IsAuthenticated == true && AuthState.CurrentUser != null)
        {
            <div class="mb-4 pb-4 border-b border-slate-700">
                <p class="text-xs text-slate-400 uppercase tracking-wide">Đang đăng nhập:</p>
                <p class="font-semibold text-white">@(AuthState.CurrentUser?.Username ?? "N/A")</p>
                <p class="text-xs text-slate-400">@(AuthState.CurrentUser?.Role ?? "N/A")</p>
            </div>
            
            <button @onclick="LogoutAsync" class="w-full px-4 py-2 bg-red-600 hover:bg-red-700 rounded text-sm font-medium transition">
                Đăng xuất
            </button>
        }
    </div>
</aside>

@code {
    [CascadingParameter]
    private AuthState? AuthState { get; set; }

    [Inject]
    private AuthService AuthService { get; set; } = default!;

    [Inject]
    private NavigationManager NavigationManager { get; set; } = default!;

    private async Task LogoutAsync()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login", forceLoad: true);
    }
}
