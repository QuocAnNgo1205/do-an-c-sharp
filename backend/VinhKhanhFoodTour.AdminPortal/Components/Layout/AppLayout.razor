@using VinhKhanhFoodTour.AdminPortal.Services.Auth
@inherits LayoutComponentBase

<Notifications @ref="NotificationComponent" />

<div class="app-container flex h-screen bg-gray-100">
    <!-- Sidebar -->
    <Sidebar />
    
    <!-- Main Content -->
    <div class="flex flex-col flex-1">
        <!-- Top Navigation -->
        <TopNav />
        
        <!-- Page Content -->
        <main class="flex-1 overflow-auto p-6">
            <article class="max-w-7xl mx-auto">
                <CascadingValue Value="NotificationComponent" IsFixed="false">
                    @Body
                </CascadingValue>
            </article>
        </main>
    </div>
</div>

@code {
    private Notifications? NotificationComponent { get; set; }
}