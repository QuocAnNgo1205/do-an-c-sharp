@page "/poi-map"
@using VinhKhanhFoodTour.AdminPortal.Services.Owner
@using VinhKhanhFoodTour.AdminPortal.Components.Layout
@inject IPoiService PoiService
@inject IJSRuntime JSRuntime

<ProtectedRoute RequiredRoles="Admin,Owner">
    <div class="h-full flex flex-col space-y-4">
        <!-- Header -->
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Bản Đồ Quán Ăn</h1>
                <p class="text-gray-600 mt-1">Quan sát trực quan toàn bộ vị trí các Point of Interest.</p>
            </div>
            
            <div class="flex gap-4 items-center">
                <!-- Map Mode Toggle -->
                <div class="flex bg-gray-200 rounded-lg p-1">
                    <button class="@(MapMode == "Pin" ? "bg-white shadow-sm font-medium text-gray-800" : "text-gray-500 hover:text-gray-700") px-4 py-1.5 rounded-md text-sm transition-all"
                            @onclick='() => ChangeMapMode("Pin")'>
                        📍 Bản đồ Ghim
                    </button>
                    
                    @if (AuthState?.IsAdmin == true)
                    {
                        <button class="@(MapMode == "Heatmap" ? "bg-white shadow-sm font-medium text-orange-600" : "text-gray-500 hover:text-gray-700") px-4 py-1.5 rounded-md text-sm transition-all flex items-center gap-1"
                                @onclick='() => ChangeMapMode("Heatmap")'>
                            🔥 Bản đồ Nhiệt (Vị trí thực tế)
                        </button>
                    }
                </div>

                <!-- Legends cho Bản đồ Ghim -->
                <div class="flex gap-2 items-center text-sm font-medium @(MapMode == "Heatmap" ? "hidden" : "")">
                    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-green-500"></span> Đã duyệt</span>
                    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-orange-500"></span> Chờ duyệt</span>
                    <span class="flex items-center gap-1"><span class="w-3 h-3 rounded-full bg-red-600"></span> Từ chối</span>
                </div>
            </div>
        </div>

        <!-- Map Container -->
        <div class="card flex-1 min-h-[600px] flex flex-col p-0 overflow-hidden relative">
            @if (IsLoading)
            {
                <div class="absolute inset-0 bg-white/80 z-50 flex flex-col items-center justify-center">
                    <div class="spinner-dot"></div>
                    <p class="mt-4 text-gray-600 font-medium">Đang tải bản đồ...</p>
                </div>
            }

            @if (MapMode == "Heatmap" && !HeatmapPoints.Any() && !IsLoading)
            {
                <div class="absolute top-4 left-1/2 -translate-x-1/2 z-[1000] bg-white shadow-lg rounded-lg p-4 border border-orange-200 flex items-center gap-4">
                    <div class="text-orange-600">
                        <i class="fas fa-exclamation-triangle"></i>
                        <span class="font-medium ml-2">Không có dữ liệu nhiệt trong 24h qua.</span>
                    </div>
                    <button class="bg-orange-600 hover:bg-orange-700 text-white px-4 py-2 rounded-md text-sm transition-colors flex items-center gap-2"
                            @onclick="HandleSeedData">
                        <i class="fas fa-magic"></i>
                        Tạo dữ liệu mẫu ngay
                    </button>
                </div>
            }

            <div id="overview-map" class="w-full h-full min-h-[600px] z-10"></div>
        </div>
    </div>
</ProtectedRoute>

@code {
    [CascadingParameter]
    private VinhKhanhFoodTour.AdminPortal.Services.Auth.AuthState? AuthState { get; set; }

    private bool IsLoading = true;
    private List<OverviewMapPinDto> Pins = new();
    private List<HeatmapPointDto> HeatmapPoints = new();
    private bool _isMapInitialized = false;
    private string MapMode = "Pin"; // "Pin" or "Heatmap"

    protected override async Task OnInitializedAsync()
    {
        try
        {
            Pins = await PoiService.GetOverviewMapPinsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error fetching map pins: {ex}");
        }
        finally
        {
            IsLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!IsLoading && !_isMapInitialized)
        {
            _isMapInitialized = true;
            await RenderMapAsync();
        }
    }

    private async Task ChangeMapMode(string mode)
    {
        if (MapMode == mode) return; 
        
        // Anti-role bypass check
        if (mode == "Heatmap" && AuthState?.IsAdmin != true)
        {
            MapMode = "Pin";
            return;
        }

        MapMode = mode;
        await RenderMapAsync();
    }

    private async Task RenderMapAsync()
    {
        try
        {
            if (MapMode == "Pin")
            {
                await JSRuntime.InvokeVoidAsync("leafletMapInterop.initOverviewMap", "overview-map", Pins);
            }
            else if (MapMode == "Heatmap")
            {
                IsLoading = true;
                StateHasChanged();
                
                try 
                {
                    HeatmapPoints = await PoiService.GetUserHeatmapPointsAsync();
                }
                finally
                {
                    IsLoading = false;
                    StateHasChanged();
                }

                await JSRuntime.InvokeVoidAsync("leafletMapInterop.renderUserHeatmap", "overview-map", HeatmapPoints, Pins);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Map render error: {ex.Message}");
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task HandleSeedData()
    {
        IsLoading = true;
        StateHasChanged();
        try
        {
            var success = await PoiService.SeedUserLocationsAsync();
            if (success)
            {
                HeatmapPoints = await PoiService.GetUserHeatmapPointsAsync();
                await RenderMapAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Seed error: {ex.Message}");
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }
}
