@page "/"
@using VinhKhanhFoodTour.AdminPortal.Services.Auth

<PageTitle>Home - Vinh Khanh CMS</PageTitle>

<ProtectedRoute>
    @if (AuthState?.IsOwner == true)
    {
        <OwnerDashboard />
    }
    else if (AuthState?.IsAdmin == true)
    {
        <AdminDashboard />
    }
    else
    {
        <div class="text-center py-10">
            <p class="text-gray-600">Unknown role or user not authenticated.</p>
        </div>
    }
</ProtectedRoute>

@code {
    [CascadingParameter]
    private AuthState? AuthState { get; set; }
}

