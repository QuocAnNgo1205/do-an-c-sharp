@using VinhKhanhFoodTour.AdminPortal.Services.Owner
@using VinhKhanhFoodTour.AdminPortal.Components.Layout
@inject NavigationManager NavManager

<Notifications @ref="NotificationComponent" />

<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-gray-800">Quán ăn của tôi</h1>
            <p class="text-gray-600 mt-1">Quản lý các địa điểm và xem thống kê của bạn</p>
        </div>
        <button @onclick="ShowAddPoiForm" class="btn btn-primary">
            📍 Thêm quán ăn mới
        </button>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="card">
            <div class="text-sm text-gray-600 uppercase tracking-wide">Tổng số quán</div>
            <div class="text-3xl font-bold text-blue-600 mt-2">@(Pois?.Count ?? 0)</div>
            <p class="text-xs text-gray-500 mt-2">@((Pois?.Count ?? 0) == 0 ? "Chưa có quán nào" : "Đang được bạn quản lý")</p>
        </div>
        <div class="card">
            <div class="text-sm text-gray-600 uppercase tracking-wide">Đã duyệt</div>
            <div class="text-3xl font-bold text-green-600 mt-2">@(Pois?.Count(p => p != null && p.Status == 1) ?? 0)</div>
            <p class="text-xs text-gray-500 mt-2">Sẵn sàng để truy cập</p>
        </div>
        <div class="card">
            <div class="text-sm text-gray-600 uppercase tracking-wide">Chờ duyệt</div>
            <div class="text-3xl font-bold text-yellow-600 mt-2">@(Pois?.Count(p => p != null && p.Status == 0) ?? 0)</div>
            <p class="text-xs text-gray-500 mt-2">Đang chờ Admin phê duyệt</p>
        </div>
    </div>

    <!-- Restaurants Table -->
    <div class="card">
        <div class="card-header">
            <h2 class="text-xl font-bold text-gray-800">Danh sách quán ăn</h2>
        </div>
        
        <div class="table-container">
            <table class="table">
                <thead>
                    <tr>
                        <th>Tên quán</th>
                        <th>Tọa độ</th>
                        <th>Trạng thái</th>
                        <th>Ngày tạo</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (IsLoading)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-8 text-gray-500">
                                Đang tải danh sách... 
                                <span class="spinner ml-2">⏳</span>
                            </td>
                        </tr>
                    }
                    else if (Pois == null || Pois.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center py-8 text-gray-500">
                                Bạn chưa có quán nào. Hãy nhấn "Thêm quán ăn mới" để bắt đầu!
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var poi in Pois.Where(p => p != null))
                        {
                            <tr>
                                <td>
                                    <div class="font-medium text-gray-900">@(poi.Name ?? "N/A")</div>
                                </td>
                                <td>
                                    <div class="text-sm text-gray-600">
                                        @poi.Latitude.ToString("F4"), @poi.Longitude.ToString("F4")
                                    </div>
                                </td>
                                <td>
                                    <span class="@GetStatusBadgeClass(poi.Status)">
                                        @GetStatusText(poi.Status)
                                    </span>
                                </td>
                                <td>
                                    <div class="text-sm text-gray-600">
                                        @(poi.CreatedAt?.ToString("MMM dd, yyyy") ?? "N/A")
                                    </div>
                                </td>
                                <td>
                                    <div class="flex gap-2">
                                        <button class="text-blue-600 hover:text-blue-800 text-sm font-medium" 
                                                @onclick="() => ViewPoiDetails(poi)">
                                            🔍 Xem
                                        </button>
                                        <button class="text-yellow-600 hover:text-yellow-800 text-sm font-medium" 
                                                @onclick="() => EditPoi(poi)">
                                            ✏️ Sửa
                                        </button>
                                        <button class="text-indigo-600 hover:text-indigo-800 text-sm font-medium"
                                                title="Tạo QR Code cho món ăn / quán này"
                                                @onclick="() => ShowQrModal(poi)">
                                            📱 QR
                                        </button>
                                        <button class="text-red-600 hover:text-red-800 text-sm font-medium" 
                                                @onclick="() => DeletePoi(poi)">
                                            🗑️ Xóa
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (ListenStats?.Count > 0)
    {
        <div class="card">
            <div class="card-header">
                <h2 class="text-xl font-bold text-gray-800">Thống kê lượt nghe thuyết minh</h2>
            </div>
            <div class="p-6">
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                    @foreach (var stat in ListenStats.Where(s => s != null))
                    {
                        <div class="bg-gradient-to-br from-blue-50 to-blue-100 p-4 rounded-lg border border-blue-200">
                            <div class="font-semibold text-gray-800">@(stat.PoiName ?? "N/A")</div>
                            <div class="text-3xl font-bold text-blue-600 mt-2">@stat.ListenCount</div>
                            <div class="text-xs text-gray-600 mt-1">narration listens</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else if (!IsLoadingStats)
    {
        <div class="card">
            <div class="card-header">
                <h2 class="text-xl font-bold text-gray-800">Thống kê lượt nghe thuyết minh</h2>
            </div>
            <div class="p-8 text-center text-gray-500">
                <p>Chưa có dữ liệu thống kê. Hãy tạo quán và chờ phê duyệt nhé!</p>
            </div>
        </div>
    }
</div>

<!-- Add POI Modal -->
@if (IsModalOpen)
{
    <AddPoiModal IsOpen="@IsModalOpen"
                 OnClose="HandleModalClose"
                 OnSuccess="HandlePoiCreated"
                 ParentNotifications="@NotificationComponent" />
}

<!-- Edit POI Modal -->
@if (IsEditModalOpen)
{
    <EditPoiModal IsOpen="@IsEditModalOpen"
                  PoiId="@SelectedPoiId"
                  OnClose="HandleEditModalClose"
                  OnSuccess="HandlePoiUpdated"
                  ParentNotifications="@NotificationComponent" />
}

<!-- QR Code Modal -->
<QrCodeModal IsOpen="@IsQrModalOpen"
             PoiId="@QrPoiId"
             PoiName="@QrPoiName"
             OnClose="HandleQrModalClose" />

@code {
    [Inject]
    private IPoiService? PoiService { get; set; }

    private Notifications? NotificationComponent { get; set; }

    private List<VinhKhanhFoodTour.AdminPortal.Services.Owner.PoiDto> Pois = new();
    private List<VinhKhanhFoodTour.AdminPortal.Services.Owner.PoiListenStatsDto> ListenStats = new();
    private bool IsModalOpen = false;
    private bool IsEditModalOpen = false;
    private int SelectedPoiId = 0;
    private bool IsLoading = true;
    private bool IsLoadingStats = true;
    private bool _isInitialized = false;

    // --- QR Code Modal State ---
    private bool IsQrModalOpen = false;
    private int QrPoiId = 0;
    private string QrPoiName = string.Empty;

    [Inject]
    private IJSRuntime? JS { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (_isInitialized) return;
        _isInitialized = true;

        try
        {
            if (PoiService == null)
            {
                NotificationComponent?.ShowNotification(
                    "Error",
                    "POI Service not available",
                    Notifications.NotificationType.Error
                );
                return;
            }

            await LoadPoisAsync();
            await LoadStatisticsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception in OwnerDashboard OnInitializedAsync: {ex}");
            NotificationComponent?.ShowNotification(
                "Error",
                $"Failed to load data.",
                Notifications.NotificationType.Error
            );
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            await base.OnAfterRenderAsync(firstRender);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception in OwnerDashboard OnAfterRenderAsync: {ex}");
        }
    }

    private async Task LoadPoisAsync()
    {
        try
        {
            IsLoading = true;
            Pois = await PoiService!.GetOwnerPoisAsync();
        }
        finally
        {
            IsLoading = false;
        }
    }

    private async Task LoadStatisticsAsync()
    {
        try
        {
            IsLoadingStats = true;
            ListenStats = await PoiService!.GetListenStatsAsync();
        }
        finally
        {
            IsLoadingStats = false;
        }
    }

    private void ShowAddPoiForm()
    {
        IsModalOpen = true;
    }

    private async Task HandleModalClose()
    {
        IsModalOpen = false;
    }

    private async Task HandlePoiCreated()
    {
        IsModalOpen = false;
        await LoadPoisAsync();
        await LoadStatisticsAsync();
        StateHasChanged();
    }

    private void ViewPoiDetails(VinhKhanhFoodTour.AdminPortal.Services.Owner.PoiDto poi)
    {
        if (poi != null)
        {
            try
            {
                NavManager.NavigateTo($"/poi/{poi.Id}");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Navigation error: {ex}");
            }
        }
    }

    private void EditPoi(VinhKhanhFoodTour.AdminPortal.Services.Owner.PoiDto poi)
    {
        SelectedPoiId = (int)poi.Id;
        IsEditModalOpen = true;
    }

    private async Task DeletePoi(VinhKhanhFoodTour.AdminPortal.Services.Owner.PoiDto poi)
    {
        if (JS == null || PoiService == null) return;

        bool confirmed = await JS.InvokeAsync<bool>("confirm", $"Bạn có chắc chắn muốn xóa quán '{poi.Name}' không? Hành động này sẽ xóa vĩnh viễn dữ liệu và các file âm thanh liên quan.");
        
        if (confirmed)
        {
            try 
            {
                IsLoading = true;
                var success = await PoiService.DeletePoiAsync((int)poi.Id);
                if (success)
                {
                    NotificationComponent?.ShowNotification("Thành công", "Đã xóa quán ăn thành công.", Notifications.NotificationType.Success);
                    await LoadPoisAsync();
                }
                else 
                {
                    NotificationComponent?.ShowNotification("Lỗi", "Không thể xóa quán ăn này.", Notifications.NotificationType.Error);
                }
            }
            catch (Exception ex)
            {
                NotificationComponent?.ShowNotification("Lỗi", $"Lỗi hệ thống khi xóa: {ex.Message}", Notifications.NotificationType.Error);
            }
            finally
            {
                IsLoading = false;
            }
        }
    }

    private void HandleEditModalClose()
    {
        IsEditModalOpen = false;
        SelectedPoiId = 0;
    }

    // --- QR Code Modal Handlers ---
    private void ShowQrModal(VinhKhanhFoodTour.AdminPortal.Services.Owner.PoiDto poi)
    {
        QrPoiId = (int)poi.Id;
        QrPoiName = poi.Name ?? "Quán ăn";
        IsQrModalOpen = true;
    }

    private void HandleQrModalClose()
    {
        IsQrModalOpen = false;
        QrPoiId = 0;
        QrPoiName = string.Empty;
    }

    private async Task HandlePoiUpdated()
    {
        IsEditModalOpen = false;
        SelectedPoiId = 0;
        await LoadPoisAsync();
        StateHasChanged();
    }

    private string GetStatusBadgeClass(int status) => status switch
    {
        1 => "badge badge-success",
        0 => "badge badge-warning",
        2 => "badge badge-error",
        _ => "badge badge-info"
    };

    private string GetStatusText(int status) => status switch
    {
        1 => "Đã duyệt",
        0 => "Đang chờ",
        2 => "Bị từ chối",
        _ => "Không xác định"
    };
}
