@using VinhKhanhFoodTour.AdminPortal.Services.Owner
@using VinhKhanhFoodTour.AdminPortal.Components.Layout
@using Microsoft.AspNetCore.Components.Forms
@inject IJSRuntime JS
@implements IAsyncDisposable

@if (IsOpen)
{
<div class="modal-overlay" @onclick="HandleBackdropClick">
    <div class="modal-content" @onclick:stopPropagation="true">
        <!-- Header -->
        <div class="modal-header">
            <div>
                <h2 class="modal-title">
                    @(!HasCreatedPoi ? "🍜 Thêm quán ăn mới" : "🎙️ Upload thuyết minh đa ngôn ngữ")
                </h2>
                @if (HasCreatedPoi)
                {
                    <p class="modal-subtitle">Tải lên file âm thanh và hình ảnh cho từng ngôn ngữ</p>
                }
            </div>
            <button @onclick="Close" class="close-btn" title="Đóng">✕</button>
        </div>

        <!-- Body -->
        <div class="modal-body">
            @if (!HasCreatedPoi)
            {
                <!-- Step 1: POI Creation Form -->
                <div class="form-section">
                    <!-- Step indicator -->
                    <div class="step-indicator">
                        <div class="step active">
                            <div class="step-circle">1</div>
                            <span>Thông tin quán</span>
                        </div>
                        <div class="step-line"></div>
                        <div class="step">
                            <div class="step-circle">2</div>
                            <span>Upload media</span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Tên quán ăn <span class="required">*</span></label>
                        <input type="text"
                               @bind="FormData.Name"
                               class="input-field"
                               placeholder="VD: Bún bò Huế Bà Tuyết" />
                    </div>

                    <div class="form-group mt-2">
                        <label class="form-label">Vị trí trên bản đồ <span class="required">*</span></label>
                        <div id="poi-map" style="height: 300px; width: 100%; border-radius: 0.5rem; z-index: 10;"></div>
                        <p class="text-xs text-gray-500 mt-1">Kéo thả Marker hoặc click vào bản đồ để chọn tọa độ</p>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label">Vĩ độ (Latitude)</label>
                            <input type="number"
                                   @bind="FormData.Latitude"
                                   step="0.000001"
                                   class="input-field bg-gray-100"
                                   readonly />
                        </div>
                        <div class="form-group">
                            <label class="form-label">Kinh độ (Longitude)</label>
                            <input type="number"
                                   @bind="FormData.Longitude"
                                   step="0.000001"
                                   class="input-field bg-gray-100"
                                   readonly />
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label">Tiêu đề (Tiếng Việt) <span class="required">*</span></label>
                        <input type="text"
                               @bind="FormData.Title"
                               class="input-field"
                               placeholder="VD: Quán bún bò ngon nhất xứ Huế" />
                    </div>

                    <div class="form-group">
                        <label class="form-label">Mô tả <span class="required">*</span></label>
                        <textarea @bind="FormData.Description"
                                  class="input-field textarea"
                                  rows="3"
                                  placeholder="Mô tả ngắn về quán ăn của bạn..."></textarea>
                    </div>

                    <!-- 🟢 FIX #2: Hình ảnh đại diện của quán (Step 1) -->
                    <div class="form-group">
                        <label class="form-label">
                            🖼️ Hình ảnh đại diện của quán (JPG/PNG) <span class="required">*</span>
                        </label>
                        <div class="file-upload-area">
                            <InputFile OnChange="HandleMainImageSelected"
                                       accept=".jpg,.jpeg,.png"
                                       class="file-input"
                                       id="main-image" />
                            <label for="main-image" class="file-label">
                                @if (MainImageFileName != null)
                                {
                                    <span class="file-selected">✅ @MainImageFileName</span>
                                }
                                else
                                {
                                    <span class="file-placeholder">
                                        <span class="upload-icon">📁</span>
                                        Chọn file ảnh đại diện...
                                    </span>
                                }
                            </label>
                        </div>
                        <p class="text-xs text-gray-500 mt-1">Ảnh này sẽ được hiển thị khi người dùng xem thông tin quán</p>
                    </div>

                    <p class="hint-text">
                        <span class="required">*</span> Các trường bắt buộc
                    </p>
                </div>
            }
            else
            {
                <!-- Step 2: Multilingual Media Upload -->
                <div class="form-section">
                    <!-- Step indicator -->
                    <div class="step-indicator">
                        <div class="step completed">
                            <div class="step-circle">✓</div>
                            <span>Thông tin quán</span>
                        </div>
                        <div class="step-line active"></div>
                        <div class="step active">
                            <div class="step-circle">2</div>
                            <span>Upload media</span>
                        </div>
                    </div>

                    <!-- Success banner -->
                    <div class="success-banner">
                        <div class="success-icon">✅</div>
                        <div>
                            <strong>Tạo quán thành công!</strong>
                            <span>ID: #@NewPoiId — Bây giờ bạn có thể upload file thuyết minh (không bắt buộc).</span>
                        </div>
                    </div>

                    <!-- Translation blocks -->
                    @for (int i = 0; i < Translations.Count; i++)
                    {
                        var index = i;
                        var translation = Translations[index];

                        <div class="translation-block">
                            <div class="translation-header">
                                <div class="translation-label">
                                    <span class="lang-badge">@GetLanguageFlag(translation.LanguageCode)</span>
                                    <span>Ngôn ngữ #@(index + 1)</span>
                                </div>
                                @if (Translations.Count > 1)
                                {
                                    <button @onclick="() => RemoveTranslation(index)"
                                            class="remove-btn"
                                            title="Xóa ngôn ngữ này">
                                        🗑️
                                    </button>
                                }
                            </div>

                            <div class="translation-body">
                                <!-- Language selector -->
                                <div class="form-group">
                                    <label class="form-label">Ngôn ngữ</label>
                                    <select @bind="translation.LanguageCode" class="input-field select-field">
                                        <option value="vi">🇻🇳 Tiếng Việt (vi)</option>
                                        <option value="en">🇬🇧 English (en)</option>
                                        <option value="ja">🇯🇵 日本語 (ja)</option>
                                        <option value="ko">🇰🇷 한국어 (ko)</option>
                                        <option value="zh">🇨🇳 中文 (zh)</option>
                                        <option value="fr">🇫🇷 Français (fr)</option>
                                    </select>
                                </div>

                                <!-- Audio upload -->
                                <div class="form-group">
                                    <label class="form-label">
                                        🎵 File thuyết minh (MP3)
                                    </label>
                                    <div class="file-upload-area">
                                        <InputFile OnChange="(e) => HandleAudioSelected(e, index)"
                                                   accept=".mp3,audio/mpeg"
                                                   class="file-input"
                                                   id="@($"audio-{index}")" />
                                        <label for="@($"audio-{index}")" class="file-label">
                                            @if (translation.AudioFileName != null)
                                            {
                                                <span class="file-selected">✅ @translation.AudioFileName</span>
                                            }
                                            else
                                            {
                                                <span class="file-placeholder">
                                                    <span class="upload-icon">📁</span>
                                                    Chọn file MP3...
                                                </span>
                                            }
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }

                    <!-- Add language button -->
                    <button @onclick="AddTranslation" class="add-lang-btn">
                        <span>＋</span> Thêm ngôn ngữ khác
                    </button>

                    <p class="hint-text">
                        💡 Bạn có thể bỏ qua bước này và upload file sau.
                    </p>
                </div>
            }
        </div>

        <!-- Footer -->
        <div class="modal-footer">
            @if (!HasCreatedPoi)
            {
                <button @onclick="Close" class="btn btn-secondary">Hủy</button>
                <button @onclick="HandleCreatePoi"
                        disabled="@(IsLoading || !IsFormValid())"
                        class="btn btn-primary">
                    @if (IsLoading)
                    {
                        <span class="spinner"></span>
                        <span>Đang tạo...</span>
                    }
                    else
                    {
                        <span>Tạo quán ăn →</span>
                    }
                </button>
            }
            else
            {
                <button @onclick="HandleSkip" class="btn btn-secondary" disabled="@IsLoading">
                    Bỏ qua
                </button>
                <button @onclick="HandleUploadMedia"
                        disabled="@IsLoading"
                        class="btn btn-primary">
                    @if (IsLoading)
                    {
                        <span class="spinner"></span>
                        <span>Đang upload... (@UploadProgress/@UploadTotal)</span>
                    }
                    else if (HasAnyMedia())
                    {
                        <span>📤 Upload & Hoàn tất</span>
                    }
                    else
                    {
                        <span>✅ Hoàn tất</span>
                    }
                </button>
            }
        </div>
    </div>
</div>
}

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback OnClose { get; set; }

    [Parameter]
    public EventCallback OnSuccess { get; set; }

    private DotNetObjectReference<AddPoiModal>? _dotNetRef;

    [Inject]
    private IPoiService? PoiService { get; set; }

    [Parameter]
    public Notifications? ParentNotifications { get; set; }

    // Step 1: POI creation
    private CreatePoiDto FormData = new();
    private IBrowserFile? MainImageFile = null;
    private string? MainImageFileName = null;
    private bool IsLoading = false;
    private bool HasCreatedPoi = false;
    private int NewPoiId = 0;

    // Step 2: Multilingual media upload
    private List<TranslationUploadModel> Translations = new();
    private int UploadProgress = 0;
    private int UploadTotal = 0;

    /// <summary>
    /// Model for each language translation upload block
    /// </summary>
    private class TranslationUploadModel
    {
        public string LanguageCode { get; set; } = "vi";
        public IBrowserFile? AudioFile { get; set; }
        public IBrowserFile? ImageFile { get; set; }
        public string? AudioFileName { get; set; }
        public string? ImageFileName { get; set; }

        public bool HasFiles => AudioFile != null || ImageFile != null;
    }

    protected override void OnInitialized()
    {
        try
        {
            FormData ??= new();
            Translations ??= new();
            
            if (Translations.Count == 0)
            {
                Translations.Add(new TranslationUploadModel { LanguageCode = "vi" });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception in AddPoiModal OnInitialized: {ex}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !HasCreatedPoi)
        {
            try
            {
                _dotNetRef ??= DotNetObjectReference.Create(this);
                await JS.InvokeVoidAsync("window.leafletMapInterop.initMap", "poi-map", _dotNetRef, FormData.Latitude, FormData.Longitude);
            }
            catch (Exception ex)
            {
                Console.WriteLine($"JS Interop Error (initMap): {ex.Message}");
            }
        }
    }

    [JSInvokable]
    public void UpdateCoordinates(double lat, double lng)
    {
        if (FormData != null)
        {
            FormData.Latitude = lat;
            FormData.Longitude = lng;
            StateHasChanged();
        }
    }

    // ── Form Validation ──

    private bool IsFormValid()
    {
        if (FormData == null) return false;
        
        return !string.IsNullOrWhiteSpace(FormData.Name) &&
               !string.IsNullOrWhiteSpace(FormData.Title) &&
               !string.IsNullOrWhiteSpace(FormData.Description) &&
               FormData.Latitude != 0 &&
               FormData.Longitude != 0 &&
               MainImageFile != null; // 🟢 Require main image
    }

    private bool HasAnyMedia()
    {
        return Translations.Any(t => t.HasFiles);
    }

    // ── Translation list management ──

    private void AddTranslation()
    {
        // Pick next available language
        var usedCodes = Translations.Select(t => t.LanguageCode).ToHashSet();
        var nextLang = new[] { "vi", "en", "ja", "ko", "zh", "fr" }
            .FirstOrDefault(c => !usedCodes.Contains(c)) ?? "en";

        Translations.Add(new TranslationUploadModel { LanguageCode = nextLang });
    }

    private void RemoveTranslation(int index)
    {
        if (Translations.Count > 1 && index >= 0 && index < Translations.Count)
        {
            Translations.RemoveAt(index);
        }
    }

    // ── File selection handlers ──

    // 🟢 NEW: Handler for main image upload (Step 1)
    private void HandleMainImageSelected(InputFileChangeEventArgs e)
    {
        MainImageFile = e.File;
        MainImageFileName = e.File.Name;
        StateHasChanged();
    }

    private void HandleAudioSelected(InputFileChangeEventArgs e, int index)
    {
        if (index >= 0 && index < Translations.Count)
        {
            Translations[index].AudioFile = e.File;
            Translations[index].AudioFileName = e.File.Name;
            StateHasChanged();
        }
    }

    private void HandleImageSelected(InputFileChangeEventArgs e, int index)
    {
        if (index >= 0 && index < Translations.Count)
        {
            Translations[index].ImageFile = e.File;
            Translations[index].ImageFileName = e.File.Name;
            StateHasChanged();
        }
    }

    // ── Step 1: Create POI ──

    private async Task HandleCreatePoi()
    {
        Console.WriteLine(">>> HandleCreatePoi called!");

        if (!IsFormValid() || PoiService == null)
        {
            Console.WriteLine(">>> HandleCreatePoi: validation failed or PoiService is null.");
            return;
        }

        try
        {
            IsLoading = true;
            
            // 🟢 FIX #3: Use CreatePoiWithImageAsync to send image with main POI data
            CreatePoiResponseDto? response = null;
            
            if (MainImageFile != null)
            {
                // 🔴 BUG FIX: Create memory stream WITHOUT using block to prevent premature disposal
                var fileStream = MainImageFile.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                var memoryStream = new MemoryStream();
                try
                {
                    await fileStream.CopyToAsync(memoryStream);
                    memoryStream.Position = 0; // Reset position for reading
                    
                    response = await PoiService.CreatePoiWithImageAsync(FormData, memoryStream, MainImageFile.Name);
                }
                finally
                {
                    // Clean up streams after HTTP request is complete
                    memoryStream?.Dispose();
                    fileStream?.Dispose();
                }
            }
            else
            {
                // Fallback to JSON (shouldn't happen due to validation)
                response = await PoiService.CreatePoiAsync(FormData);
            }

            NewPoiId = response.Id;
            HasCreatedPoi = true;

            // Ensure at least 1 translation block exists
            if (Translations.Count == 0)
            {
                Translations.Add(new TranslationUploadModel { LanguageCode = "vi" });
            }

            ParentNotifications?.ShowNotification(
                "Thành công",
                "Đã tạo quán ăn! Bạn có thể upload file thuyết minh bên dưới.",
                Notifications.NotificationType.Success
            );
        }
        catch (Exception ex)
        {
            ParentNotifications?.ShowNotification(
                "Lỗi",
                $"Không thể tạo quán: {ex.Message}",
                Notifications.NotificationType.Error
            );
        }
        finally
        {
            IsLoading = false;
        }
    }

    // ── Step 2: Upload media for all translations ──

    private async Task HandleUploadMedia()
    {
        if (PoiService == null) return;

        // Get only translations that have files
        var translationsWithFiles = Translations.Where(t => t.HasFiles).ToList();

        // No files selected → just close and report success
        if (translationsWithFiles.Count == 0)
        {
            ParentNotifications?.ShowNotification(
                "Hoàn tất",
                "Đã tạo quán ăn thành công! Bạn có thể upload thuyết minh sau.",
                Notifications.NotificationType.Success
            );
            await Reset();
            await OnSuccess.InvokeAsync();
            return;
        }

        try
        {
            IsLoading = true;
            UploadProgress = 0;
            UploadTotal = translationsWithFiles.Count;
            int successCount = 0;
            var errors = new List<string>();

            foreach (var translation in translationsWithFiles)
            {
                UploadProgress++;
                StateHasChanged();

                try
                {
                    var content = new MultipartFormDataContent();

                    if (translation.AudioFile != null)
                    {
                        var audioStream = translation.AudioFile.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
                        content.Add(new StreamContent(audioStream), "audioFile", translation.AudioFile.Name);
                    }

                    if (translation.ImageFile != null)
                    {
                        var imageStream = translation.ImageFile.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
                        content.Add(new StreamContent(imageStream), "imageFile", translation.ImageFile.Name);
                    }

                    await PoiService.UploadMediaAsync(NewPoiId, translation.LanguageCode, content);
                    successCount++;
                }
                catch (Exception ex)
                {
                    errors.Add($"[{translation.LanguageCode}]: {ex.Message}");
                }
            }

            if (errors.Count == 0)
            {
                ParentNotifications?.ShowNotification(
                    "Hoàn tất! ✅",
                    $"Đã upload thuyết minh cho {successCount} ngôn ngữ thành công!",
                    Notifications.NotificationType.Success
                );
            }
            else
            {
                ParentNotifications?.ShowNotification(
                    "Cảnh báo",
                    $"Upload {successCount} thành công, {errors.Count} lỗi: {string.Join("; ", errors)}",
                    Notifications.NotificationType.Warning
                );
            }

            await Reset();
            await OnSuccess.InvokeAsync();
        }
        catch (Exception ex)
        {
            ParentNotifications?.ShowNotification(
                "Lỗi",
                $"Lỗi upload media: {ex.Message}",
                Notifications.NotificationType.Error
            );
        }
        finally
        {
            IsLoading = false;
        }
    }

    // ── Skip/Close ──

    private async Task HandleSkip()
    {
        ParentNotifications?.ShowNotification(
            "Hoàn tất",
            "Đã tạo quán ăn thành công! Bạn có thể upload thuyết minh sau.",
            Notifications.NotificationType.Success
        );
        await Reset();
        await OnSuccess.InvokeAsync();
    }

    private async Task HandleBackdropClick()
    {
        try
        {
            if (IsOpen && !IsLoading)
                await Close();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception in HandleBackdropClick: {ex}");
        }
    }

    public async Task Close()
    {
        try
        {
            await JS.InvokeVoidAsync("window.leafletMapInterop.destroyMap");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"JS Interop Error (destroyMap): {ex.Message}");
        }
        
        await Reset();
        await OnClose.InvokeAsync();
    }

    private async Task Reset()
    {
        FormData = new();
        MainImageFile = null;  // 🟢 Clear main image
        MainImageFileName = null;  // 🟢 Clear main image name
        HasCreatedPoi = false;
        NewPoiId = 0;
        Translations = new List<TranslationUploadModel>
        {
            new() { LanguageCode = "vi" }
        };
        UploadProgress = 0;
        UploadTotal = 0;
        IsLoading = false;
    }

    // ── Helpers ──

    private string GetLanguageFlag(string code) => code switch
    {
        "vi" => "🇻🇳",
        "en" => "🇬🇧",
        "ja" => "🇯🇵",
        "ko" => "🇰🇷",
        "zh" => "🇨🇳",
        "fr" => "🇫🇷",
        _ => "🌐"
    };

    public async ValueTask DisposeAsync()
    {
        if (_dotNetRef != null)
        {
            _dotNetRef.Dispose();
            _dotNetRef = null;
        }
        try
        {
            await JS.InvokeVoidAsync("window.leafletMapInterop.destroyMap");
        }
        catch { /* ignore in dispose */ }
    }
}
