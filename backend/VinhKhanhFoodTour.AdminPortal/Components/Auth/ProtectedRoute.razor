@using VinhKhanhFoodTour.AdminPortal.Services.Auth

@if (AuthState?.IsAuthenticated == true)
{
    @if (CheckRoleAccess())
    {
        @ChildContent
    }
    else
    {
        <div class="min-h-screen flex items-center justify-center bg-gray-100">
            <div class="text-center">
                <h1 class="text-4xl font-bold text-gray-800 mb-4">403</h1>
                <p class="text-xl text-gray-600 mb-6">You don't have permission to access this page.</p>
                <p class="text-gray-600 mb-6">Your role is: <strong>@(AuthState.CurrentUser?.Role ?? "Unknown")</strong></p>
                <a href="/" class="inline-block px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                    Back to Dashboard
                </a>
            </div>
        </div>
    }
}
else
{
    <div class="min-h-screen flex items-center justify-center bg-gray-100">
        <div class="text-center">
            <h1 class="text-4xl font-bold text-gray-800 mb-4">Unauthorized</h1>
            <p class="text-xl text-gray-600 mb-6">Please log in to access this page.</p>
            <a href="/login" class="inline-block px-6 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
                Go to Login
            </a>
        </div>
    </div>
}

@code {
    [CascadingParameter]
    private AuthState? AuthState { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Optional: Specify required roles (e.g., "Admin,Owner")
    /// If not set, any authenticated user can access
    /// </summary>
    [Parameter]
    public string? RequiredRoles { get; set; }

    private bool CheckRoleAccess()
    {
        if (string.IsNullOrEmpty(RequiredRoles) || AuthState?.CurrentUser == null)
            return true;

        var roles = RequiredRoles.Split(',').Select(r => r.Trim()).ToList();
        return roles.Contains(AuthState.CurrentUser.Role);
    }
}
