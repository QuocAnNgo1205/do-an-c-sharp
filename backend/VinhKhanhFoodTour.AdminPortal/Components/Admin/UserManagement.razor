@page "/admin/users"
@using VinhKhanhFoodTour.AdminPortal.Services.Admin
@using VinhKhanhFoodTour.AdminPortal.Models.Auth
@using VinhKhanhFoodTour.AdminPortal.Components.Layout
<ProtectedRoute RequiredRoles="Admin">
    <div class="space-y-6">
        <!-- Header -->
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">Quản lý người dùng</h1>
                <p class="text-gray-600 mt-1">Quản lý tài khoản hệ thống, vai trò và quyền truy cập.</p>
            </div>
            <div class="flex gap-3">
                <button @onclick="() => ShowAddModal = true" class="btn btn-approve">
                    ➕ Thêm người dùng mới
                </button>
                <button @onclick="LoadUsersAsync" class="btn btn-secondary" disabled="@IsLoading">
                    🔄 Làm mới
                </button>
            </div>
        </div>

        <!-- Stats Cards -->
        @if (Stats != null)
        {
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="card">
                    <div class="text-sm text-gray-600 uppercase tracking-wide">Tổng tài khoản</div>
                    <div class="text-3xl font-bold text-purple-600 mt-2">@Stats.TotalUsers</div>
                    <p class="text-xs text-gray-500 mt-2">Toàn bộ hệ thống</p>
                </div>
                <div class="card">
                    <div class="text-sm text-gray-600 uppercase tracking-wide">Người Tải App (Tourists)</div>
                    <div class="text-3xl font-bold text-blue-600 mt-2">@Stats.TotalTourists</div>
                    <p class="text-xs text-gray-500 mt-2">Sử dụng dịch vụ Audio Guide</p>
                </div>
                <div class="card">
                    <div class="text-sm text-gray-600 uppercase tracking-wide">Chủ Quán (Owners)</div>
                    <div class="text-3xl font-bold text-orange-600 mt-2">@Stats.TotalOwners</div>
                    <p class="text-xs text-gray-500 mt-2">Đăng ký kinh doanh ẩm thực</p>
                </div>
            </div>
        }

        <!-- Users Table -->
        <div class="card">
            <div class="card-header">
                <h2 class="text-xl font-bold text-gray-800">Người dùng hệ thống</h2>
            </div>
            
            <div class="table-container">
                <table class="table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Thông tin</th>
                            <th>Vai trò</th>
                            <th>Trạng thái</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (IsLoading)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-8 text-gray-500">
                                    <div class="spinner-dot mx-auto mb-3"></div>
                                    Đang tải người dùng...
                                </td>
                            </tr>
                        }
                        else if (Users == null || Users.Count == 0)
                        {
                            <tr>
                                <td colspan="5" class="text-center py-8 text-gray-500">
                                    Không tìm thấy người dùng nào trong hệ thống.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var user in Users.Where(u => u != null))
                            {
                                <tr>
                                    <td>
                                        <span class="text-xs font-mono text-gray-500">#@user.Id</span>
                                    </td>
                                    <td>
                                        <div>
                                            <div class="font-medium text-gray-900">@(user.Username ?? "Không rõ")</div>
                                            @if (!string.IsNullOrEmpty(user.Email))
                                            {
                                                <div class="text-sm text-gray-500">@user.Email</div>
                                            }
                                            else 
                                            {
                                                <div class="text-xs text-gray-400 italic">Chưa cập nhật email</div>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="@GetRoleBadgeClass(user.RoleName ?? "Tourist")">
                                            @(user.RoleName ?? "Unknown")
                                        </span>
                                    </td>
                                    <td>
                                        @if (user.IsActive)
                                        {
                                            <span class="badge badge-success">Hoạt động</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-error">Đã khóa</span>
                                        }
                                    </td>
                                    <td>
                                        <button 
                                            class="@(user.IsActive ? "btn btn-reject text-sm" : "btn btn-approve text-sm")" 
                                            @onclick="() => ToggleUserStatusAsync(user)"
                                            disabled="@(ProcessingUserId == user.Id || (user.RoleName == "Admin" && user.IsActive))"
                                            title="@(user.RoleName == "Admin" && user.IsActive ? "Cannot block an active admin directly" : "")">
                                            
                                            @if (ProcessingUserId == user.Id)
                                            {
                                                <span>⏳ Đang xử lý...</span>
                                            }
                                            else if (user.IsActive)
                                            {
                                                <span>🔒 Khóa</span>
                                            }
                                            else
                                            {
                                                <span>🔓 Mở khóa</span>
                                            }
                                        </button>

                                        <button 
                                            class="btn btn-reject text-sm ml-2" 
                                            @onclick="() => ConfirmDeleteUser(user)"
                                            disabled="@(ProcessingUserId == user.Id)"
                                            title="Xóa người dùng này vĩnh viễn">
                                            🗑️ Xóa
                                        </button>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    @if (ShowAddModal)
    {
        <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-md overflow-hidden">
                <div class="bg-gray-50 px-6 py-4 border-b flex justify-between items-center">
                    <h3 class="text-xl font-bold text-gray-800">Thêm người dùng mới</h3>
                    <button @onclick="() => ShowAddModal = false" class="text-gray-400 hover:text-gray-600">✕</button>
                </div>
                
                <EditForm Model="@NewUser" OnValidSubmit="HandleAddUserAsync" class="p-6 space-y-4">
                    <DataAnnotationsValidator />
                    
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tên đăng nhập</label>
                        <InputText @bind-Value="NewUser.Username" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-orange-500 outline-none" placeholder="Nhập tên đăng nhập" />
                        <ValidationMessage For="@(() => NewUser.Username)" class="text-red-500 text-xs mt-1" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Địa chỉ Email</label>
                        <InputText @bind-Value="NewUser.Email" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-orange-500 outline-none" placeholder="Nhập email" />
                        <ValidationMessage For="@(() => NewUser.Email)" class="text-red-500 text-xs mt-1" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Mật khẩu</label>
                        <InputText @bind-Value="NewUser.Password" type="password" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-orange-500 outline-none" placeholder="Nhập mật khẩu" />
                        <ValidationMessage For="@(() => NewUser.Password)" class="text-red-500 text-xs mt-1" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Vai trò</label>
                        <InputSelect @bind-Value="NewUser.RoleName" class="w-full px-4 py-2 border rounded-lg focus:ring-2 focus:ring-orange-500 outline-none">
                            <option value="Tourist">Khách du lịch (App)</option>
                            <option value="Owner">Chủ quán (Cửa hàng)</option>
                            <option value="Admin">Quản trị viên</option>
                        </InputSelect>
                    </div>

                    <div class="flex gap-3 pt-4 border-t">
                        <button type="button" @onclick="() => ShowAddModal = false" class="flex-1 px-4 py-2 border rounded-lg hover:bg-gray-50 transition-colors">
                            Hủy
                        </button>
                        <button type="submit" class="flex-1 px-4 py-2 bg-orange-500 text-white rounded-lg hover:bg-orange-600 transition-colors font-bold" disabled="@IsSubmitting">
                            @(IsSubmitting ? "Đang tạo..." : "Tạo người dùng")
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    }

    @if (UserToDelete != null)
    {
        <div class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
            <div class="bg-white rounded-xl shadow-2xl w-full max-w-sm overflow-hidden anim-pop">
                <div class="p-6 text-center">
                    <div class="w-16 h-16 bg-red-100 text-red-600 rounded-full flex items-center justify-center mx-auto mb-4 text-2xl">
                        ⚠️
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Xác nhận xóa</h3>
                    <p class="text-gray-600 mb-6">
                        Bạn có chắc chắn muốn xóa user <strong>@UserToDelete.Username</strong> không? <br/>
                        <span class="text-red-500 text-sm italic font-medium">Hành động này không thể hoàn tác!</span>
                    </p>
                    <div class="flex gap-3">
                        <button @onclick="() => UserToDelete = null" class="flex-1 px-4 py-2 border rounded-lg hover:bg-gray-50 transition-colors">
                            Hủy
                        </button>
                        <button @onclick="HandleDeleteUserAsync" class="flex-1 px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors font-bold">
                            Đồng ý Xóa
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</ProtectedRoute>

@code {
    [Inject]
    private IAdminService? AdminService { get; set; }

    private Notifications? NotificationComponent { get; set; }

    private List<UserDto> Users = new();
    private UserStatsDto? Stats = null;
    private bool IsLoading = true;
    private bool _isInitialized = false;
    private int? ProcessingUserId = null;

    // Modal Add State
    private bool ShowAddModal = false;
    private bool IsSubmitting = false;
    private CreateUserDto NewUser = new();

    // Modal Delete State
    private UserDto? UserToDelete = null;

    protected override async Task OnInitializedAsync()
    {
        if (_isInitialized) return;
        _isInitialized = true;

        try
        {
            await LoadUsersAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception in UserManagement OnInitializedAsync: {ex}");
            NotificationComponent?.ShowNotification(
                "Error",
                "Failed to initialize user management.",
                Notifications.NotificationType.Error
            );
        }
    }

    private async Task LoadUsersAsync()
    {
        if (AdminService == null) return;

        IsLoading = true;
        try
        {
            Users = await AdminService.GetUsersAsync();
            Stats = await AdminService.GetUserStatsAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception loading users: {ex}");
            NotificationComponent?.ShowNotification(
                "Error",
                "Failed to load user list from server.",
                Notifications.NotificationType.Error
            );
        }
        finally
        {
            IsLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ToggleUserStatusAsync(UserDto user)
    {
        if (user == null || AdminService == null) return;

        ProcessingUserId = user.Id;
        try
        {
            var result = await AdminService.ToggleUserStatusAsync(user.Id);
            
            // Toggle local state to avoid full reload
            user.IsActive = !user.IsActive;

            NotificationComponent?.ShowNotification(
                "Success",
                result.Message ?? "User status updated successfully.",
                Notifications.NotificationType.Success
            );
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Exception toggling user: {ex}");
            NotificationComponent?.ShowNotification(
                "Error",
                "Failed to update user status. Cannot block the last admin.",
                Notifications.NotificationType.Error
            );
        }
        finally
        {
            ProcessingUserId = null;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task HandleAddUserAsync()
    {
        if (AdminService == null) return;

        IsSubmitting = true;
        try
        {
            var result = await AdminService.AddUserAsync(NewUser);
            
            NotificationComponent?.ShowNotification(
                "Success",
                result.Message,
                Notifications.NotificationType.Success
            );

            ShowAddModal = false;
            NewUser = new(); // Reset
            await LoadUsersAsync(); // Reload list
        }
        catch (Exception)
        {
            NotificationComponent?.ShowNotification(
                "Add User Failed",
                "Username already exists or systemic error.",
                Notifications.NotificationType.Error
            );
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void ConfirmDeleteUser(UserDto user)
    {
        UserToDelete = user;
    }

    private async Task HandleDeleteUserAsync()
    {
        if (UserToDelete == null || AdminService == null) return;

        var targetUserId = UserToDelete.Id;
        UserToDelete = null; // Close modal
        
        ProcessingUserId = targetUserId;
        try
        {
            var result = await AdminService.DeleteUserAsync(targetUserId);
            
            NotificationComponent?.ShowNotification(
                "Deleted",
                result.Message,
                Notifications.NotificationType.Success
            );

            await LoadUsersAsync();
        }
        catch (Exception)
        {
            NotificationComponent?.ShowNotification(
                "Delete Error",
                "Không thể xóa user này (có thể do dính quán ăn/POI hoặc là chính bạn).",
                Notifications.NotificationType.Error
            );
        }
        finally
        {
            ProcessingUserId = null;
        }
    }

    private string GetRoleBadgeClass(string roleName) => roleName switch
    {
        "Admin" => "badge bg-purple-100 text-purple-800 border-purple-200",
        "Owner" => "badge badge-info",
        _ => "badge badge-warning" // Tourist or unknown
    };
}
