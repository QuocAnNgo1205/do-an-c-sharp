<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
            xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFoodTour.MainPage"
             Title="Vinh Khanh Food Tour"
             BackgroundColor="#F5F5F5">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Status and Tracking Section -->
        <StackLayout Spacing="10" Padding="15" BackgroundColor="White">
            
            <!-- Title -->
            <Label Text="Location Tracking" FontSize="20" FontAttributes="Bold" TextColor="#333333" />

            <!-- Current Location Display -->
            <Frame BorderColor="#CCCCCC" CornerRadius="8" Padding="12" HasShadow="False">
                <VerticalStackLayout Spacing="5">
                    <Label Text="Current Location:" FontSize="12" TextColor="#666666" FontAttributes="Bold" />
                    <Label Text="{Binding CurrentLocationText}" FontSize="14" TextColor="#333333" />
                </VerticalStackLayout>
            </Frame>

            <!-- Status Message -->
            <Frame BorderColor="#E0E0E0" CornerRadius="8" Padding="12" BackgroundColor="#F9F9F9" HasShadow="False">
                <Label Text="{Binding StatusMessage}" FontSize="13" TextColor="#555555" />
            </Frame>

            <!-- Control Buttons -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                
                <!-- Start Tracking Button -->
                <Button Text="Start Tracking"
                        Clicked="OnStartTrackingClicked"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="14"
                        CornerRadius="8"
                        Padding="10,15"
                        Grid.Column="0" />

                <!-- Stop Tracking Button -->
                <Button Text="Stop Tracking"
                        Clicked="OnStopTrackingClicked"
                        BackgroundColor="#F44336"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="14"
                        CornerRadius="8"
                        Padding="10,15"
                        Grid.Column="1" />

            </Grid>
            <maps:Map x:Name="FoodTourMap" 
          IsShowingUser="True" 
          HeightRequest="400" />
        </StackLayout>

        <!-- Narration Log Section -->
        <StackLayout Spacing="8">
            <Label Text="Narration Log" FontSize="18" FontAttributes="Bold" TextColor="#333333" />

            <!-- ListView showing triggered narrations -->
            <CollectionView IsGrouped="False" 
                           ItemsSource="{Binding NarrationLog}"
                           SelectionMode="Single"
                           SelectionChangedCommand="{Binding SelectionChangedCommand}"
                           HeightRequest="300">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BorderColor="#DDDDDD" 
                               CornerRadius="8" 
                               Padding="12" 
                               Margin="0,5"
                               HasShadow="False"
                               BackgroundColor="White">
                            <VerticalStackLayout Spacing="6">
                                
                                <!-- POI Name and Timestamp -->
                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                    <Label Text="{Binding PoiName}" 
                                           FontSize="14" 
                                           FontAttributes="Bold" 
                                           TextColor="#2196F3"
                                           Grid.Column="0" />
                                    <Label Text="{Binding TriggeredAt, StringFormat='{0:HH:mm:ss}'}" 
                                           FontSize="12" 
                                           TextColor="#999999"
                                           Grid.Column="1" />
                                </Grid>

                                <!-- Narration Text -->
                                <Label Text="{Binding NarrationText}" 
                                       FontSize="12" 
                                       TextColor="#555555"
                                       LineBreakMode="WordWrap"
                                       MaxLines="3" />

                                <!-- User Location -->
                                <Label Text="{Binding UserLocation}" 
                                       FontSize="11" 
                                       TextColor="#888888"
                                       FontAttributes="Italic" />

                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </StackLayout>

        <!-- Footer Info -->
        <Label Text="App Status: Ready"
               FontSize="12"
               TextColor="#999999"
               HorizontalTextAlignment="Center"
               Margin="0,10,0,0" />

    </VerticalStackLayout>

</ContentPage>
