<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:VinhKhanhFoodTour.App.PageModels"
             xmlns:models="clr-namespace:VinhKhanhFoodTour.App.Models"
             xmlns:services="clr-namespace:VinhKhanhFoodTour.App.Services"
             x:Class="VinhKhanhFoodTour.App.Pages.ProjectDetailPage"
             x:DataType="pageModels:ProjectDetailPageModel"
             Title="{services:Translate PlaceDetailTitle}"
             BackgroundColor="#0F0F0F">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <Grid HeightRequest="320">
                <Image Source="{Binding Poi.FullImageUrl}" 
                       Aspect="AspectFill" 
                       HorizontalOptions="Fill" />

                <BoxView VerticalOptions="End" HeightRequest="80">
                    <BoxView.Background>
                        <LinearGradientBrush EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0" />
                            <GradientStop Color="#1A1A1A" Offset="1" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>
            </Grid>

            <Border Margin="0,-35,0,0" 
                    Padding="25" 
                    StrokeThickness="0" 
                    BackgroundColor="#1A1A1A" 
                    StrokeShape="RoundRectangle 35,35,0,0">

                <VerticalStackLayout Spacing="18">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding Poi.Name}" 
                               FontSize="28" 
                               FontAttributes="Bold" 
                               TextColor="#FF5722" />

                        <Label Text="{Binding Poi.Title}" 
                               FontSize="14" 
                               TextColor="#888888" 
                               FontAttributes="Italic" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,5">
                        <Button Grid.Column="0" 
                                Text="{services:Translate MapButton}"
                                Command="{Binding OpenMapCommand}"
                                BackgroundColor="#2C2C2E" 
                                TextColor="White" 
                                FontAttributes="Bold" 
                                CornerRadius="28" 
                                HeightRequest="56">
                            <Button.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Opacity="0.2" Radius="6" />
                            </Button.Shadow>
                        </Button>

                        <Grid Grid.Column="1">
                            <Button Text="{services:Translate AudioPlay}"
                                    Command="{Binding ToggleAudioCommand}"
                                    BackgroundColor="#FF6F00" 
                                    TextColor="White" 
                                    FontAttributes="Bold" 
                                    CornerRadius="28" 
                                    HeightRequest="56">
                                <Button.Shadow>
                                    <Shadow Brush="Black" Offset="0,4" Opacity="0.2" Radius="6" />
                                </Button.Shadow>
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Text" Value="{services:Translate AudioStop}" />
                                        <Setter Property="BackgroundColor" Value="#D32F2F" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            
                            <ActivityIndicator IsVisible="{Binding IsLoadingAudio}"
                                               IsRunning="{Binding IsLoadingAudio}"
                                               Color="White"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               HeightRequest="30" WidthRequest="30" />
                        </Grid>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#2A2A2A" Margin="0,10" />

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Giới thiệu điểm đến" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="#FFC107"/>

                        <Label Text="{Binding DisplayDescription}" 
                               FontSize="16" 
                               TextColor="#D0D0D0" 
                               LineHeight="1.5" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="#2C2C2E" 
                            StrokeShape="RoundRectangle 20" 
                            StrokeThickness="0"
                            Padding="20,15" 
                            Margin="0,10,0,20">
                        <Grid ColumnDefinitions="Auto, *" ColumnSpacing="15">
                            <Frame Grid.Column="0" WidthRequest="40" HeightRequest="40" CornerRadius="20" BackgroundColor="#3A3A3C" Padding="0" HasShadow="False" VerticalOptions="Center">
                                <Label Text="📍" HorizontalOptions="Center" VerticalOptions="Center" FontSize="18"/>
                            </Frame>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                <Label Text="{services:Translate AddressLabel}" TextColor="#888888" FontSize="11" FontAttributes="Bold" TextTransform="Uppercase"/>
                                <Label Text="{Binding Poi.Title}" TextColor="White" FontSize="15" FontAttributes="Bold" />
                                <Label Text="{Binding Poi.Address}" TextColor="#AAAAAA" FontSize="13" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>