<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:VinhKhanhFoodTour.App.PageModels"
             xmlns:models="clr-namespace:VinhKhanhFoodTour.App.Models"
             x:Class="VinhKhanhFoodTour.App.Pages.ProjectDetailPage"
             x:DataType="pageModels:ProjectDetailPageModel"
             Title="Thông tin chi tiết"
             BackgroundColor="#0F0F0F">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <Grid HeightRequest="320">
                <Image Source="{Binding Poi.ImageUrl}" 
                       Aspect="AspectFill" 
                       HorizontalOptions="Fill" />

                <BoxView VerticalOptions="End" HeightRequest="80">
                    <BoxView.Background>
                        <LinearGradientBrush EndPoint="0,1">
                            <GradientStop Color="Transparent" Offset="0" />
                            <GradientStop Color="#1A1A1A" Offset="1" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>
            </Grid>

            <Border Margin="0,-35,0,0" 
                    Padding="25" 
                    StrokeThickness="0" 
                    BackgroundColor="#1A1A1A" 
                    StrokeShape="RoundRectangle 35,35,0,0">

                <VerticalStackLayout Spacing="18">

                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding Poi.Name}" 
                               FontSize="28" 
                               FontAttributes="Bold" 
                               TextColor="#FF5722" />

                        <Label Text="{Binding Poi.Title}" 
                               FontSize="14" 
                               TextColor="#888888" 
                               FontAttributes="Italic" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,5">
                        <Button Grid.Column="0" 
                                Text="📍 BẢN ĐỒ"
                                Command="{Binding OpenMapCommand}"
                                BackgroundColor="#2196F3" 
                                TextColor="White" 
                                FontAttributes="Bold" 
                                CornerRadius="12" 
                                HeightRequest="55" />

                        <Grid Grid.Column="1">
                            <Button Text="🔊 THUYẾT MINH"
                                    Command="{Binding ToggleAudioCommand}"
                                    BackgroundColor="#FFC107" 
                                    TextColor="#121212" 
                                    FontAttributes="Bold" 
                                    CornerRadius="12" 
                                    HeightRequest="55">
                                <Button.Triggers>
                                    <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="True">
                                        <Setter Property="Text" Value="⏹️ DỪNG PHÁT" />
                                        <Setter Property="BackgroundColor" Value="#F44336" />
                                        <Setter Property="TextColor" Value="White" />
                                    </DataTrigger>
                                </Button.Triggers>
                            </Button>
                            
                            <ActivityIndicator IsVisible="{Binding IsLoadingAudio}"
                                               IsRunning="{Binding IsLoadingAudio}"
                                               Color="#121212"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center"
                                               HeightRequest="30" WidthRequest="30" />
                        </Grid>
                    </Grid>

                    <BoxView HeightRequest="1" Color="#333333" Margin="0,5" />

                    <VerticalStackLayout Spacing="10">
                        <Label Text="Giới thiệu điểm đến" 
                               FontSize="20" 
                               FontAttributes="Bold" 
                               TextColor="#FFC107"/>

                        <Label Text="{Binding Poi.Description}" 
                               FontSize="16" 
                               TextColor="#D0D0D0" 
                               LineHeight="1.5" />
                    </VerticalStackLayout>

                    <Border BackgroundColor="#252525" 
                            StrokeShape="RoundRectangle 12" 
                            Padding="15" 
                            Margin="0,10,0,20">
                        <HorizontalStackLayout Spacing="15" HorizontalOptions="Center">
                            <Label Text="📍 Vị trí GPS:" TextColor="#888888" FontSize="12"/>
                            <Label Text="{Binding Poi.Latitude, StringFormat='Lat: {0:F4}'}" TextColor="#AAAAAA" FontSize="12"/>
                            <Label Text="{Binding Poi.Longitude, StringFormat='Lng: {0:F4}'}" TextColor="#AAAAAA" FontSize="12"/>
                        </HorizontalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>