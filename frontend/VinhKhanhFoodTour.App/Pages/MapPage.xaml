<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
             xmlns:services="clr-namespace:VinhKhanhFoodTour.App.Services"
             x:Class="VinhKhanhFoodTour.App.Pages.MapPage"
             Title="{services:Translate TabMap}">

    <Grid>
        <!-- Bản đồ nạp pins -->
        <maps:Map x:Name="foodMap" 
                  IsShowingUser="True" 
                  MapType="Street">
        </maps:Map>

        <!-- Floating UI Control Center -->
        <Border VerticalOptions="End" 
                HorizontalOptions="Center" 
                Margin="20,0,20,30"
                Padding="15,10"
                StrokeShape="RoundRectangle 20"
                StrokeThickness="0"
                BackgroundColor="#C01A1A1A"
                HeightRequest="70"
                ZIndex="100">
            <!-- Glassmorphism effect background -->
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,5" Opacity="0.5" Radius="10" />
            </Border.Shadow>
            
            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="15" VerticalOptions="Center">
                <Label Grid.Column="0" Text="📍" FontSize="24" VerticalOptions="Center" />
                
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                    <Label Text="SMART AUDIO GUIDE" FontSize="12" FontAttributes="Bold" TextColor="#FFC107" CharacterSpacing="1" />
                    <Label Text="{services:Translate AutoPlaySubtitle}" FontSize="10" TextColor="#AAAAAA" />
                </VerticalStackLayout>

                <Switch Grid.Column="2" 
                        x:Name="autoPlaySwitch"
                        OnColor="#FFC107" 
                        ThumbColor="White" 
                        VerticalOptions="Center"
                        Toggled="OnAutoPlayToggled" />
            </Grid>
        </Border>

        <!-- Vùng nền mờ (Tap để đóng card) - PHẢI đặt TRƯỚC InfoCard để InfoCard hiển thị trên nó -->
        <BoxView x:Name="DimOverlay"
                 BackgroundColor="#80000000"
                 IsVisible="False"
                 ZIndex="150">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnOverlayTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- ====== INFO CARD (Hiện khi nhấn Pin) - PHẢI đặt SAU DimOverlay ====== -->
        <Border x:Name="InfoCard"
                VerticalOptions="End"
                HorizontalOptions="Fill"
                IsVisible="False"
                Margin="0"
                Padding="0,0,0,0"
                StrokeShape="RoundRectangle 24,24,0,0"
                StrokeThickness="0"
                BackgroundColor="#1A1A1A"
                ZIndex="200">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-4" Opacity="0.6" Radius="20" />
            </Border.Shadow>

            <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="0">
                <!-- Thanh kéo (drag handle) -->
                <BoxView Grid.Row="0"
                         WidthRequest="40" HeightRequest="4"
                         Color="#555555"
                         CornerRadius="2"
                         HorizontalOptions="Center"
                         Margin="0,12,0,8" />

                <!-- Ảnh quán (Bo góc) -->
                <Border Grid.Row="1"
                        Margin="16,0,16,0"
                        StrokeShape="RoundRectangle 16"
                        StrokeThickness="0">
                    <Image x:Name="CardImage"
                           Aspect="AspectFill"
                           HeightRequest="180"
                           HorizontalOptions="Fill" />
                </Border>

                <!-- Thông tin và nút bấm -->
                <VerticalStackLayout Grid.Row="2" Padding="16,12,16,24" Spacing="10">

                    <!-- Tên & Mô tả -->
                    <Label x:Name="CardName"
                           FontSize="20"
                           FontAttributes="Bold"
                           TextColor="#FF5722" />

                    <Label x:Name="CardTitle"
                           FontSize="14"
                           TextColor="#CCCCCC"
                           MaxLines="2"
                           LineBreakMode="TailTruncation" />

                    <!-- 2 Nút hành động Cải Tiến -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,0">
                        <Button Grid.Column="0"
                                x:Name="BtnSpeak"
                                Text="{services:Translate AudioPlay}"
                                BackgroundColor="#FF6F00"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="24"
                                HeightRequest="46"
                                FontSize="13"
                                Clicked="OnSpeakClicked">
                            <Button.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Opacity="0.2" Radius="6" />
                            </Button.Shadow>
                        </Button>

                        <Button Grid.Column="1"
                                Text="{services:Translate ViewDetail}"
                                BackgroundColor="#2C2C2E"
                                TextColor="White"
                                FontAttributes="Bold"
                                CornerRadius="24"
                                HeightRequest="46"
                                FontSize="13"
                                Clicked="OnDetailClicked">
                            <Button.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Opacity="0.2" Radius="6" />
                            </Button.Shadow>
                        </Button>
                    </Grid>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>


</ContentPage>