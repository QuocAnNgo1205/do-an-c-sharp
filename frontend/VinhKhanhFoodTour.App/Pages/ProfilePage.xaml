<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:VinhKhanhFoodTour.App.PageModels"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="VinhKhanhFoodTour.App.Pages.ProfilePage"
             x:DataType="pageModels:ProfilePageModel"
             Title="Hồ sơ">

    <ContentPage.Resources>
        <toolkit:IsNotNullConverter x:Key="IsNotNullConverter" />
    </ContentPage.Resources>

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding LoadProfileDataCommand}" />
    </ContentPage.Behaviors>

    <ScrollView BackgroundColor="#0F0F0F">
        <VerticalStackLayout Spacing="25" Padding="20">
            <!-- Header Phần người dùng -->
            <Grid ColumnDefinitions="Auto, *, Auto" Padding="0,5">
                <Border Grid.Column="0" StrokeThickness="0" StrokeShape="RoundRectangle 25" HeightRequest="50" WidthRequest="50" BackgroundColor="Orange">
                    <Label Text="👤" FontSize="25" HorizontalOptions="Center" VerticalOptions="Center" />
                </Border>
                
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Margin="15,0">
                    <Label Text="{Binding UserName}" FontSize="18" FontAttributes="Bold" TextColor="White" />
                    <Label Text="{Binding UserRole}" FontSize="11" TextColor="#FFC107" CharacterSpacing="1" />
                </VerticalStackLayout>

                <Button Grid.Column="2" 
                        Text="🚪 Logout" 
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="Transparent"
                        TextColor="#FF5252"
                        FontSize="11"
                        BorderWidth="1"
                        BorderColor="#80FF5252"
                        CornerRadius="8"
                        Padding="12,5"
                        VerticalOptions="Center" />
            </Grid>

            <BoxView HeightRequest="1" Color="#333333" Margin="0,5" />

            <!-- PHẦN MỚI: QUÁN ĂN TIÊU BIỂU (Lấy từ Pois) -->
            <VerticalStackLayout Spacing="15" IsVisible="{Binding FeaturedPoi, Converter={StaticResource IsNotNullConverter}}">
                <Label Text="🍽️ QUÁN ĂN BẠN QUAN TÂM" FontSize="16" FontAttributes="Bold" TextColor="#FFC107" />
                
                <Border StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="#1A1A1A" Padding="15">
                    <VerticalStackLayout Spacing="12">
                        <Image Source="{Binding FeaturedPoi.ImageUrl}" 
                               HeightRequest="180" 
                               Aspect="AspectFill" 
                               HorizontalOptions="Fill" />

                        <Label Text="{Binding FeaturedPoi.Name}" 
                               FontSize="22" 
                               FontAttributes="Bold" 
                               TextColor="#FF5722" />

                        <Label Text="{Binding FeaturedPoi.Description}" 
                               FontSize="14" 
                               TextColor="#D0D0D0" 
                               LineHeight="1.4" />

                        <!-- Nút Audio đồng nhất với MainPage/Detail -->
                        <Grid ColumnDefinitions="*, Auto" ColumnSpacing="10" Margin="0,5">
                            <Grid Grid.Column="0">
                                <Button Text="🔊 NGHE GIỚI THIỆU"
                                        Command="{Binding ToggleAudioCommand}"
                                        BackgroundColor="#FFC107" 
                                        TextColor="#121212" 
                                        FontAttributes="Bold" 
                                        CornerRadius="10" 
                                        HeightRequest="45">
                                    <Button.Triggers>
                                        <DataTrigger TargetType="Button" Binding="{Binding FeaturedPoi.IsPlaying}" Value="True">
                                            <Setter Property="Text" Value="⏹️ DỪNG PHÁT" />
                                            <Setter Property="BackgroundColor" Value="#F44336" />
                                            <Setter Property="TextColor" Value="White" />
                                        </DataTrigger>
                                    </Button.Triggers>
                                </Button>
                                
                                <ActivityIndicator IsVisible="{Binding FeaturedPoi.IsLoadingAudio}"
                                                   IsRunning="{Binding FeaturedPoi.IsLoadingAudio}"
                                                   Color="#121212"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"
                                                   HeightRequest="25" WidthRequest="25" />
                            </Grid>

                            <Button Grid.Column="1" Text="XEM CHI TIẾT" 
                                    BackgroundColor="#252525" TextColor="White" FontSize="11" CornerRadius="10" Padding="15,0" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- PHẦN MỚI: CHỌN QUỐC GIA & NGÔN NGỮ THUYẾT MINH -->
            <VerticalStackLayout Spacing="15">
                <Label Text="🌍 QUỐC GIA &amp; NGÔN NGỮ" FontSize="16" FontAttributes="Bold" TextColor="#FFC107" />
                
                <Border StrokeShape="RoundRectangle 15" StrokeThickness="0" BackgroundColor="#1A1A1A" Padding="0">
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding AvailableLanguages}" Spacing="0">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="pageModels:LanguageInfo">
                                <Grid ColumnDefinitions="Auto, *, Auto" Padding="15,12">
                                    <Grid.GestureRecognizers>
                                        <TapGestureRecognizer 
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:ProfilePageModel}}, Path=SelectLanguageCommand}"
                                            CommandParameter="{Binding .}" />
                                    </Grid.GestureRecognizers>
                                    
                                    <Label Grid.Column="0" Text="{Binding Flag}" FontSize="24" VerticalOptions="Center" />
                                    <Label Grid.Column="1" Text="{Binding Name}" FontSize="15" TextColor="White" Margin="15,0" VerticalOptions="Center" />
                                    
                                    <!-- Indicator Checkmark -->
                                    <Label Grid.Column="2" Text="✓" TextColor="#FFC107" FontSize="18" FontAttributes="Bold" 
                                           VerticalOptions="Center"
                                           IsVisible="False">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" 
                                                         Binding="{Binding Code}" 
                                                         Value="{Binding Source={RelativeSource AncestorType={x:Type pageModels:ProfilePageModel}}, Path=SelectedLanguage.Code}">
                                                <Setter Property="IsVisible" Value="True" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </Grid>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                </Border>
                <Label Text="💡 Hệ thống sẽ tự động phát thuyết minh bằng ngôn ngữ này khi bạn đến gần quán ăn." 
                       FontSize="11" TextColor="#888888" LineBreakMode="WordWrap" />
            </VerticalStackLayout>

            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" 
                             VerticalOptions="Center" HorizontalOptions="Center" Color="Orange" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>