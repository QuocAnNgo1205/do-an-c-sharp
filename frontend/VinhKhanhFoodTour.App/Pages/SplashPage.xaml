<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhFoodTour.App.Pages.SplashPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F0F0F">

    <Grid RowDefinitions="*, Auto, *">
        <!-- Vùng Logo ở giữa -->
        <VerticalStackLayout Grid.Row="1"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Spacing="24">

            <!-- Icon App (Dùng emoji hoặc thay bằng image nếu có) -->
            <Label Text="🍜"
                   FontSize="72"
                   HorizontalOptions="Center" />

            <!-- Tên App -->
            <Label Text="Vĩnh Khánh Food Tour"
                   FontSize="26"
                   FontAttributes="Bold"
                   TextColor="#FFC107"
                   HorizontalOptions="Center" />

            <Label Text="Thiên đường ẩm thực Quận 4"
                   FontSize="14"
                   TextColor="#888888"
                   HorizontalOptions="Center" />

            <!-- Loading Dots -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="True"
                               IsVisible="True"
                               Color="#FFC107"
                               HeightRequest="30"
                               WidthRequest="30"
                               HorizontalOptions="Center"
                               Margin="0,10,0,0" />
        </VerticalStackLayout>

        <!-- Version nhỏ ở dưới cùng -->
        <Label Grid.Row="2"
               Text="v1.0 · Do An Tot Nghiep"
               FontSize="11"
               TextColor="#444444"
               HorizontalOptions="Center"
               VerticalOptions="End"
               Margin="0,0,0,20" />
    </Grid>
</ContentPage>
