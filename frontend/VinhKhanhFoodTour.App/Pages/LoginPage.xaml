<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:VinhKhanhFoodTour.App.PageModels"
             x:Class="VinhKhanhFoodTour.App.Pages.LoginPage"
             x:DataType="pageModels:LoginViewModel"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F0F0F">

    <Grid>
        <!-- Background Gradient Effect (Subtle) -->
        <BoxView BackgroundColor="#1A1A1A" HeightRequest="300" VerticalOptions="Start" TranslationY="-150">
            <BoxView.Clip>
                <EllipseGeometry Center="200,100" RadiusX="300" RadiusY="200" />
            </BoxView.Clip>
        </BoxView>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Spacing="25" Padding="30">
                
                <!-- Logo/Icon -->
                <VerticalStackLayout Spacing="10" HorizontalOptions="Center" Margin="0,20">
                    <Border StrokeThickness="0" StrokeShape="RoundRectangle 25" HeightRequest="80" WidthRequest="80" BackgroundColor="#FFC107">
                        <Label Text="🐚" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Text="VINH KHANH" FontSize="20" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" CharacterSpacing="2" />
                    <Label Text="AUTHENTIC FOOD TOUR" FontSize="10" TextColor="#888888" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="5">
                    <Label Text="Đăng Nhập" FontSize="28" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Vui lòng đăng nhập để tiếp tục hành trình." FontSize="14" TextColor="#B0B0B0" />
                </VerticalStackLayout>

                <!-- Form -->
                <VerticalStackLayout Spacing="15" Margin="0,10">
                    <Border StrokeShape="RoundRectangle 12" BackgroundColor="#1A1A1A" StrokeThickness="1" Stroke="#333333" Padding="15,0">
                        <Entry Placeholder="Tên đăng nhập" 
                               Text="{Binding Username}" 
                               TextColor="White" 
                               PlaceholderColor="#555555" 
                               HeightRequest="50" />
                    </Border>

                    <Border StrokeShape="RoundRectangle 12" BackgroundColor="#1A1A1A" StrokeThickness="1" Stroke="#333333" Padding="15,0">
                        <Entry Placeholder="Mật khẩu" 
                               Text="{Binding Password}" 
                               IsPassword="True" 
                               TextColor="White" 
                               PlaceholderColor="#555555" 
                               HeightRequest="50" />
                    </Border>
                    
                    <Label Text="Quên mật khẩu?" TextColor="#FFC107" FontSize="13" HorizontalOptions="End" />
                </VerticalStackLayout>

                <!-- Actions -->
                <VerticalStackLayout Spacing="15">
                    <Button Text="ĐĂNG NHẬP" 
                            Command="{Binding LoginCommand}" 
                            BackgroundColor="#FFC107" 
                            TextColor="#121212" 
                            FontAttributes="Bold" 
                            HeightRequest="55" 
                            CornerRadius="12" />

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="5">
                        <Label Text="Chưa có tài khoản?" TextColor="#888888" />
                        <Label Text="Đăng ký ngay" TextColor="#FFC107" FontAttributes="Bold">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToRegisterCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <ActivityIndicator IsRunning="{Binding IsBusy}" Color="#FFC107" HorizontalOptions="Center" Margin="0,10" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
