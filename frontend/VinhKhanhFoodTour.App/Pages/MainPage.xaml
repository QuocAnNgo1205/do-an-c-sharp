<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pageModels="clr-namespace:VinhKhanhFoodTour.App.PageModels"             
             xmlns:models="clr-namespace:VinhKhanhFoodTour.App.Models"
             xmlns:services="clr-namespace:VinhKhanhFoodTour.App.Services"
             xmlns:pullToRefresh="clr-namespace:Syncfusion.Maui.Toolkit.PullToRefresh;assembly=Syncfusion.Maui.Toolkit"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="VinhKhanhFoodTour.App.Pages.MainPage"
             x:DataType="pageModels:MainPageModel"
             Title="{services:Translate TabPlaces}"
             BackgroundColor="#0F0F0F">

    <ContentPage.Behaviors>
        <toolkit:EventToCommandBehavior EventName="Appearing" Command="{Binding AppearingCommand}" />
    </ContentPage.Behaviors>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Margin="15,10" Padding="5,0" HeightRequest="45" 
                BackgroundColor="#1E1E1E" StrokeThickness="0" ZIndex="10">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <SearchBar Placeholder="{services:Translate SearchPlaceholder}" PlaceholderColor="#888888" TextColor="White"
                       Text="{Binding SearchText}" 
                       SearchCommand="{Binding SearchCommand}"
                       CancelButtonColor="Orange" BackgroundColor="Transparent" />
        </Border>

        <pullToRefresh:SfPullToRefresh Grid.Row="1"
            IsRefreshing="{Binding IsRefreshing}"
            RefreshCommand="{Binding RefreshCommand}">

            <pullToRefresh:SfPullToRefresh.PullableContent>
                <CollectionView ItemsSource="{Binding Restaurants}" SelectionMode="None">
                    <CollectionView.Header>
                        <VerticalStackLayout Padding="20,10,20,15" Spacing="5">
                            <Label Text="{services:Translate FoodStreetTitle}" FontSize="24" FontAttributes="Bold" TextColor="#FFC107" />
                            <Label Text="{services:Translate FoodStreetDesc}" FontSize="13" TextColor="#888888" />
                            <!-- Tiêu đề Danh sách Tour -->
                            <Label Text="{services:Translate DiscoverTour}" FontSize="18" FontAttributes="Bold" TextColor="White" Margin="0,15,0,5" />
                            <HorizontalStackLayout Spacing="4" Margin="0,0,0,10">
                                <Label Text="{Binding ToursList.Count}" FontSize="13" TextColor="#888888"/>
                                <Label Text="{services:Translate AvailableTours}" FontSize="13" TextColor="#888888"/>
                            </HorizontalStackLayout>

                            <!-- CollectionView Cuộn Ngang Danh sách Tour (Text only) -->
                            <CollectionView ItemsSource="{Binding ToursList}" HorizontalOptions="Fill" HeightRequest="85" SelectionMode="None">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Horizontal" ItemSpacing="12" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:Tour">
                                        <Border WidthRequest="200" Margin="0,5,0,10" StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="#1E1E1E">
                                            <Border.Shadow>
                                                <Shadow Brush="Black" Offset="0,2" Opacity="0.2" Radius="4" />
                                            </Border.Shadow>
                                            
                                            <Grid Padding="12,8" ColumnDefinitions="*, Auto">
                                                <VerticalStackLayout Grid.Column="0" VerticalOptions="Center" Spacing="2">
                                                    <Label Text="{Binding Title}" FontSize="14" FontAttributes="Bold" TextColor="White" MaxLines="1" LineBreakMode="TailTruncation" />
                                                    <HorizontalStackLayout Spacing="3">
                                                        <Label Text="📍" FontSize="11" />
                                                        <Label Text="{Binding NumberOfStops}" FontSize="11" TextColor="#AAAAAA" />
                                                        <Label Text="{services:Translate StopsText}" FontSize="11" TextColor="#AAAAAA" />
                                                        <Label Text="•" FontSize="11" TextColor="#AAAAAA" Margin="2,0"/>
                                                        <Label Text="{Binding Duration}" FontSize="11" TextColor="#AAAAAA" />
                                                        <Label Text="{services:Translate MinsText}" FontSize="11" TextColor="#AAAAAA" />
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>
                                                
                                                <Label Grid.Column="1" Text="➜" FontSize="16" TextColor="#FF5722" 
                                                       VerticalOptions="Center" HorizontalOptions="Center" Margin="5,0,0,0" />

                                                <!-- Nhấn vào Card để Mở Tour Detail -->
                                                <Grid.GestureRecognizers>
                                                    <TapGestureRecognizer 
                                                        Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:MainPageModel}}, Path=GoToTourCommand}"
                                                        CommandParameter="{Binding .}" />
                                                </Grid.GestureRecognizers>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                            
                            <!-- Tiêu đề Danh sách Quán (Tách bạch khỏi Tours) -->
                            <Label Text="{services:Translate AllPlaces}" FontSize="18" FontAttributes="Bold" TextColor="White" Margin="0,20,0,0" />
                        </VerticalStackLayout>
                    </CollectionView.Header>

                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Poi">
                            <Border Margin="15,0,15,20" StrokeShape="RoundRectangle 20" StrokeThickness="0" BackgroundColor="#1A1A1A">
                                <VerticalStackLayout>
                                    <!-- Phần 1: Click vào ảnh hoặc tên để xem chi tiết -->
                                    <VerticalStackLayout Spacing="0">
                                        <VerticalStackLayout.GestureRecognizers>
                                            <TapGestureRecognizer 
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:MainPageModel}}, Path=GoToDetailCommand}"
                                                CommandParameter="{Binding .}" />
                                        </VerticalStackLayout.GestureRecognizers>

                                        <Border StrokeShape="RoundRectangle 20,20,0,0" StrokeThickness="0" Margin="0" Padding="0">
                                            <Image Aspect="AspectFill" HeightRequest="200" HorizontalOptions="Fill" Source="{Binding FullImageUrl}" />
                                        </Border>

                                        <VerticalStackLayout Padding="15,15,15,5" Spacing="8">
                                            <Label Text="{Binding Name}" FontSize="20" FontAttributes="Bold" TextColor="#FF5722" />

                                            <!-- Badge hiển thị khoảng cách -->
                                            <Border StrokeThickness="0" 
                                                    BackgroundColor="#252528"
                                                    HorizontalOptions="Start"
                                                    Padding="10,5,10,5">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="8" />
                                                </Border.StrokeShape>
                                                <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                                    <Label Text="📍" FontSize="13" VerticalOptions="Center" />
                                                    <Label Text="{Binding DistanceDisplay}" 
                                                           TextColor="#FFC107" 
                                                           FontSize="13" 
                                                           FontAttributes="Bold" 
                                                           VerticalOptions="Center" />
                                                </HorizontalStackLayout>
                                            </Border>

                                            <Label Text="{Binding Title}" FontSize="14" TextColor="#B0B0B0" MaxLines="2" />
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>

                                    <!-- Phần 2: Các nút bấm (Nằm ngoài vùng Gesture để tránh xung đột) -->
                                    <VerticalStackLayout Padding="15,0,15,15">
                                        <Grid ColumnDefinitions="*, *" ColumnSpacing="12" Margin="0,5,0,0">
                                            
                                            <!-- Nút Thuyết Minh Cải Tiến -->
                                            <Grid Grid.Column="0">
                                                <Button Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:MainPageModel}}, Path=SpeakCommand}"
                                                        CommandParameter="{Binding .}"
                                                        CornerRadius="24" HeightRequest="46" FontSize="13" FontAttributes="Bold" TextColor="White">
                                                    <Button.Shadow>
                                                        <Shadow Brush="Black" Offset="0,4" Opacity="0.2" Radius="6" />
                                                    </Button.Shadow>
                                                    <Button.Triggers>
                                                        <!-- Khi đang KHÔNG phát nhạc thì màu xanh -->
                                                        <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="False">
                                                            <Setter Property="Text" Value="{services:Translate AudioPlay}" />
                                                            <Setter Property="BackgroundColor" Value="#FF6F00" /> <!-- Đổi sang Cam năng động thay vì xanh lá -->
                                                        </DataTrigger>
                                                        <!-- Khi ĐANG phát nhạc thì chuyển thành màu đỏ -->
                                                        <DataTrigger TargetType="Button" Binding="{Binding IsPlaying}" Value="True">
                                                            <Setter Property="Text" Value="{services:Translate AudioStop}" />
                                                            <Setter Property="BackgroundColor" Value="#D32F2F" />
                                                        </DataTrigger>
                                                    </Button.Triggers>
                                                </Button>

                                                <ActivityIndicator IsVisible="{Binding IsLoadingAudio}"
                                                                   IsRunning="{Binding IsLoadingAudio}"
                                                                   Color="White" HorizontalOptions="Center" VerticalOptions="Center" 
                                                                   HeightRequest="25" WidthRequest="25" />
                                            </Grid>

                                            <!-- Nút Chi Tiết Cải Tiến -->
                                            <Button Grid.Column="1" Text="{services:Translate ViewDetail}" 
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type pageModels:MainPageModel}}, Path=GoToDetailCommand}"
                                                    CommandParameter="{Binding .}"
                                                    BackgroundColor="#2C2C2E" TextColor="White" FontAttributes="Bold" 
                                                    CornerRadius="24" HeightRequest="46" FontSize="13">
                                                 <Button.Shadow>
                                                    <Shadow Brush="Black" Offset="0,4" Opacity="0.2" Radius="6" />
                                                 </Button.Shadow>
                                            </Button>
                                        </Grid>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </pullToRefresh:SfPullToRefresh.PullableContent>
        </pullToRefresh:SfPullToRefresh>
    </Grid>
</ContentPage>