<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Cấu hình cho phép kết nối HTTP (Cleartext) tới bất kỳ địa chỉ nào trong lúc phát triển -->
    <base-config cleartextTrafficAllowed="true">
        <trust-anchors>
            <certificates src="system" />
            <certificates src="user" />
        </trust-anchors>
    </base-config>
</network-security-config>
